# Copy to .env and fill in real values before running deploy.sh.
# .env is gitignored — NEVER commit it.

# ---- Hysteria2 ----
# Public IP or hostname clients will connect to (used in the clash template).
HY_SERVER_HOST=your.server.ip.or.host

# trafficStats API secret (also used by the subscription panel and auth backend).
# Generate with: openssl rand -hex 24
HY_API_SECRET=replace_me_with_openssl_rand_hex_24

# Salamander obfs password. Generate with: openssl rand -base64 24 | tr -d '/+='
HY_OBFS_PASSWORD=replace_me_with_random_32_chars

# ---- Xray VLESS + Reality ----
# Generate a keypair with: xray x25519
XRAY_REALITY_PRIVATE_KEY=replace_me_reality_private_key
XRAY_REALITY_PUBLIC_KEY=replace_me_reality_public_key

# Short ID (hex, even length, 2-16 chars). Generate with: openssl rand -hex 8
XRAY_REALITY_SHORT_ID=replace_me_hex_8

# Client UUID. Generate with: xray uuid   (or: uuidgen)
XRAY_CLIENT_UUID=replace_me_uuid
